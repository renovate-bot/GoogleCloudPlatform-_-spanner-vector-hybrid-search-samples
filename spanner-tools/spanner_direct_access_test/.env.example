# GCP project that owns the Spanner instance/database.
GCP_PROJECT_ID=

# Spanner target for the benchmark app and local repo workflows.
SPANNER_INSTANCE_ID=
SPANNER_DATABASE_ID=

# Optional credentials override. Leave blank to use Application Default Credentials.
# Example: /path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=

# Optional benchmark defaults for the Java app.
BENCHMARK_APP_NAME=spanner-benchmark-poc
BENCHMARK_DEFAULT_WARMUP_ITERATIONS=10
BENCHMARK_DEFAULT_MEASURED_ITERATIONS=100
BENCHMARK_DEFAULT_CONCURRENCY=1

GOOGLE_SPANNER_ENABLE_DIRECT_ACCESS=true